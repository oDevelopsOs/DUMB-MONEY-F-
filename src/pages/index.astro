---
import Base from '../layouts/Base.astro';
import AuthorByline from '../components/AuthorByline.astro';
import SeoSchema from '../components/SeoSchema.astro';

const lastUpdated = '2026-04-24';
const published = '2026-04-24';
const faqItems = [
  {
    question: 'What is payment for order flow (PFOF)?',
    answer:
      'PFOF is when a broker routes your order to a market maker that pays for that flow. The broker gets paid, and your execution quality may vary by routing incentives.',
  },
  {
    question: 'Is commission-free trading really free?',
    answer:
      'No. The explicit fee may be zero, but the economics can show up in spread capture, routing priorities, and execution quality differences.',
  },
  {
    question: 'Does Dumb Money execute trades or provide financial advice?',
    answer:
      'No. Dumb Money is an intelligence and research platform. It does not execute orders and does not provide personalized investment advice.',
  },
  {
    question: 'Which sources does Dumb Money use for market-structure claims?',
    answer:
      'Primary sources such as SEC disclosures, FINRA enforcement records, and official broker filings, with methodology transparency for updates and corrections.',
  },
  {
    question: 'How often is this content updated?',
    answer:
      'Core market-structure content is updated continuously, with accelerated updates when material regulatory or enforcement developments happen.',
  },
  {
    question: 'Who writes and reviews the research?',
    answer:
      'Content is prepared by the Dumb Money Research Desk and reviewed against source quality, evidence traceability, and correction policy standards.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---
<Base
  title="DUMB MONEY - The market works perfectly. For them."
  description="Your broker calls you a client. Citadel calls you inventory. DUMB MONEY gives retail investors institutional-grade intelligence."
  modifiedTime={new Date(`${lastUpdated}T00:00:00.000Z`).toISOString()}
  publishedTime={new Date(`${published}T00:00:00.000Z`).toISOString()}
  authorName="Dumb Money Research Desk"
>
  <main>
    <nav class="dm-nav">
      <a href="/" class="brand-link" aria-label="Dumb Money home">
        <img
          src="/dumb-money-logo.png"
          alt="Dumb Money logo"
          class="brand-logo"
          width="320"
          height="320"
          decoding="async"
        />
      </a>
      <a href="#waitlist" class="btn btn-small">I want access</a>
    </nav>

    <section class="section hero" id="hero">
      <div class="container hero-inner">
        <div class="hero-bg-mark" aria-hidden="true">THEM</div>
        <div class="hero-content reveal">
          <p class="kicker">This is a line in the sand.</p>
          <h1 class="display hero-title-main">The market has worked perfectly for decades.</h1>
          <h1 class="display hero-title-acid">For <span>them.</span></h1>
          <p class="lead">
            Your broker calls you a client. Citadel calls you inventory.
            <strong> We call it what it is: you are the product.</strong>
          </p>
          <div class="hero-cta">
            <a href="#crime" id="hero-primary-cta" class="btn ripple-container magnetic">Show me how this game is rigged</a>
            <span class="micro-copy">Not a newsletter. Not a hype thread. Full receipts.</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-alt" aria-label="Answer first summary">
      <div class="container">
        <p class="kicker reveal">TL;DR</p>
        <p class="paragraph reveal">
          Payment for order flow is not free magic; it is a routing business model with incentives that can diverge from your execution quality. Dumb Money explains that system with source-backed, retail-first intelligence.
        </p>
      </div>
    </section>

    <section class="section section-dark crime scan-lines" id="crime">
      <div class="container">
        <p class="kicker acid reveal">The crime</p>
        <h2 class="display h2 reveal">“Free trading” is the most successful financial scam since “I love you” in an MLM pitch.</h2>
        <p class="paragraph reveal">
          When you place an order on Robinhood, eToro, or any app yelling “democratizing finance,”
          your order often does not go to market first. It takes a VIP detour through Citadel, Virtu, or G1.
          They process it, keep the spread, and tip your broker for delivering you.
        </p>
        <p class="paragraph reveal">
          In 2021, major US brokers made <strong>$3.8B</strong> from payment for order flow.
          Robinhood made <strong>$974M</strong> from this model then, around <strong>$1.79B</strong> in 2024,
          and <strong>83%</strong> of retail equity order flow ran through three firms.
        </p>
        <p class="paragraph reveal">
          Then came GameStop: retail finally pushed back, and buy buttons suddenly “needed a nap.”
          Sell stayed live. Totally normal. Totally not a panic call from someone's hedge-fund buddy.
        </p>
        <div class="tag-list reveal">
          <span class="tag">PFOF</span>
          <span class="tag">Citadel</span>
          <span class="tag">GameStop</span>
          <span class="tag">SEC fines</span>
        </div>
      </div>
    </section>

    <section class="section section-alt numbers" id="numbers">
      <div class="container">
        <p class="kicker reveal">The numbers</p>
        <h2 class="display h2 reveal">Not opinions. Math with a grudge.</h2>
        <div class="stats-grid reveal">
          <article class="scard">
            <p class="count-up stat-value" data-target="$3.8B">$0B</p>
            <p class="stat-label">Broker revenue from selling your flow in one year. Nice business model.</p>
          </article>
          <article class="scard">
            <p class="count-up stat-value coral-value" data-target="$34.1M">$0M</p>
            <p class="stat-label">Inferior execution harm estimated by the SEC for a specific retail order slice.</p>
          </article>
          <article class="scard">
            <p class="count-up stat-value acid-value" data-target="83%">0%</p>
            <p class="stat-label">Retail order flow concentrated in three execution firms. Competition vibes.</p>
          </article>
          <article class="scard">
            <p class="count-up stat-value" data-target="$32K">$0K</p>
            <p class="stat-label">Bloomberg terminal cost per desk, per year (rough 2025-2026 range).</p>
          </article>
          <article class="scard">
            <p class="count-up stat-value coral-value" data-target="6.1%">0%</p>
            <p class="stat-label">Long-run annual retail underperformance vs S&P. Not stupidity. Information gap.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section section-dark mirror" id="mirror">
      <div class="container">
        <p class="kicker acid reveal">The mirror</p>
        <h2 class="display h2 reveal">
          If you've ever felt the market was playing against you, you were not paranoid.
        </h2>
        <p class="paragraph reveal">
          You studied. You read. You did more homework than a med student on caffeine.
          You bought when it made sense. Then it moved against you and someone in a vest said “you are too emotional.”
        </p>
        <p class="paragraph reveal">
          Nobody told you that while you were reading one headline, an institutional stack
          had already processed the same event across multiple languages, data feeds, and order-flow layers.
        </p>
        <p class="paragraph reveal">
          You did not fail because you are bad at investing.
          You were trading yesterday's information against systems trading in microseconds.
        </p>
      </div>
    </section>

    <section class="section section-alt verdict" id="verdict">
      <div class="container">
        <p class="kicker reveal">The verdict</p>
        <h2 class="display h2 reveal">
          The system is not broken. But access to the intelligence behind it is no longer exclusive.
        </h2>
        <p class="paragraph navy reveal">
          Their edge had two pillars: capital and information.
          Capital is still theirs. Information does not have to be.
        </p>
        <p class="paragraph navy reveal">
          The point is not to copy Wall Street's ethics.
          The point is to turn asymmetry into something you can actually fight with.
        </p>
        <a href="#waitlist" class="btn btn-secondary reveal">Fine. I'm listening.</a>
      </div>
    </section>

    <section class="section section-dark solution" id="solution">
      <div class="container">
        <p class="kicker acid reveal">The weapon</p>
        <h2 class="display h2 reveal">They built the casino. You just learned to count cards.</h2>
        <p class="paragraph reveal">
          DUMB MONEY is not a brokerage app. It does not scream “buy this now.”
          It is an intelligence system for investors who prefer context over dopamine.
        </p>
        <div class="solution-grid">
          <article class="solution-card dark reveal">
            <span class="solution-index">01</span>
            <h3>The Oracle</h3>
            <p>
              Nineteen specialized agents track macro, geopolitics, company risk, and supply-chain pressure
              in real time over your portfolio.
            </p>
          </article>
          <article class="solution-card dark reveal">
            <span class="solution-index">02</span>
            <h3>The Stress Test</h3>
            <p>
              Leadership quality, financial durability, geopolitical exposure, and execution risk mapped
              per position. Think of it as a colonoscopy for your holdings, but less awkward.
            </p>
          </article>
          <article class="solution-card dark reveal">
            <span class="solution-index">03</span>
            <h3>The Radar</h3>
            <p>
              Cross-asset signals and factor matrix tied to your real holdings. Not generic market noise.
              The kind they used to hide behind expensive terminals and old-boy networks.
            </p>
          </article>
        </div>
        <a href="#waitlist" class="btn btn-secondary reveal">Give me access before this goes mainstream</a>
      </div>
    </section>

    <section class="section section-alt social-proof" id="social-proof">
      <div class="container">
        <p class="kicker reveal">Social proof</p>
        <h2 class="display h2 reveal">People are done being someone else's liquidity.</h2>
        <div class="proof-grid">
          <article class="proof-card reveal">
            <p>“First time I can explain why my semiconductor position reacts to supply-chain signals. Now I sound dangerous at dinner.”</p>
            <h3>Tom, 28 — Madrid</h3>
          </article>
          <article class="proof-card reveal">
            <p>“Three years investing, nobody explained PFOF this clearly. Turns out I was the ball, not the player.”</p>
            <h3>Lea, 31 — Brussels</h3>
          </article>
          <article class="proof-card reveal">
            <p>“This feels like actual research, not influencer theater. No one has tried to sell me a course yet.”</p>
            <h3>Nico, 26 — Buenos Aires</h3>
          </article>
        </div>
      </div>
    </section>

    <section class="section manifesto" id="manifesto">
      <div class="container reveal">
        <blockquote class="display quote">
          The financial system has always been designed so a few win from many.
          <span>That does not change overnight. Access does.</span>
        </blockquote>
        <p class="paragraph navy">
          We did not build another app to tell you what to buy.
          We built an intelligence layer for people who refuse to invest blind and call that “normal.”
        </p>
      </div>
    </section>

    <section id="waitlist" class="section waitlist">
      <div class="container">
        <p class="kicker navy reveal">Pick a side</p>
        <h2 class="display h2 navy reveal">Be first in.</h2>
        <p class="paragraph navy reveal">
          Active development. Priority access list. Limited seats because we are shipping with real
          users and real feedback, not fake scarcity copy. (If we faked scarcity we'd at least hire better writers.)
        </p>
        <p class="counter-copy reveal"><span id="counter">-</span> people already picked their side.</p>
        <div id="form-wrapper" class="form-wrapper reveal">
          <form id="waitlist-form" class="waitlist-form">
            <input type="email" id="email-input" placeholder="you@not-exit-liquidity.com" required autocomplete="email" />
            <textarea id="expectation-input" rows="3" placeholder="What are you missing most as an investor right now? (optional)"></textarea>
            <input
              type="text"
              id="company-input"
              name="company"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
              style="position:absolute;left:-10000px;opacity:0;pointer-events:none;"
            />
            <button id="submit-btn" type="submit" class="btn btn-dark ripple-container magnetic">I'm in</button>
          </form>
          <p class="form-microcopy">No spam. No newsletter. One notification when we open access. Your email is never sold. Ironically, we have standards.</p>
          <p id="form-status" class="form-status" aria-live="polite"></p>
        </div>
        <div id="success-wrapper" class="success-wrapper" hidden>
          <div class="success-msg">
            <h3 class="display h3 navy">You're in. Now it gets interesting.</h3>
            <p class="paragraph navy">
              We will notify you when access opens.
              Bring one friend who is tired of being called “dumb money.”
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-alt" id="faq">
      <div class="container">
        <p class="kicker reveal">FAQ</p>
        <h2 class="display h2 reveal">Straight answers to the questions people actually ask.</h2>
        <div class="proof-grid">
          {faqItems.map((item) => (
            <article class="proof-card reveal">
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-dark">
      <div class="container">
        <p class="kicker acid reveal">Editorial trust</p>
        <h2 class="display h2 reveal">Built with explicit standards, not vibes.</h2>
        <AuthorByline author="Dumb Money Research Desk" reviewer="Market Structure Editor" date={lastUpdated} />
        <p class="paragraph reveal">
          Read our <a href="/methodology">methodology</a>, <a href="/corrections">corrections policy</a>, and <a href="/press">press contact page</a>.
        </p>
      </div>
    </section>

    <footer class="dm-footer">
      <div class="container footer-grid">
        <div class="footer-brand-block">
          <a href="/" class="brand-link" aria-label="Dumb Money home">
            <img
              src="/dumb-money-logo.png"
              alt="Dumb Money logo"
              class="brand-logo footer-brand-logo"
              width="320"
              height="320"
              loading="lazy"
              decoding="async"
            />
          </a>
          <p class="footer-copy">OMK Intelligence — what they know, now you know.</p>
          <p class="footer-copy">Author: Dumb Money Research Desk</p>
          <p class="footer-copy">Last updated: <time datetime={lastUpdated}>{lastUpdated}</time></p>
          <p class="footer-legal">
            OMK Intelligence is a market intelligence tool. It does not provide financial advice
            or investment recommendations. If you want financial advice, ask the guy who sold you “free” trading.
          </p>
        </div>
        <div class="footer-links" aria-label="Footer links">
          <a href="/about">About</a>
          <a href="/pfof">PFOF hub</a>
          <a href="/pfof-calculator">PFOF calculator</a>
          <a href="/data/pfof-routing-dataset">Dataset</a>
          <a href="/methodology">Methodology</a>
          <a href="/corrections">Corrections</a>
          <a href="/press">Press</a>
          <a href="/seo-ops">SEO/GEO ops</a>
          <a href="/privacy">Privacy</a>
          <a href="mailto:gm@dumbmoney.io">Contact</a>
          <a href="https://twitter.com/dumbmoneyio">@dumbmoneyio</a>
        </div>
      </div>
    </footer>
  </main>
  <SeoSchema schema={faqSchema} />
</Base>

<script>
  const waitlistEndpoint = '/api/waitlist';
  const navElement = document.querySelector('.dm-nav');
  let lastScrollY = window.scrollY;

  document.querySelectorAll('.ripple-container').forEach((btn) => {
    btn.addEventListener('click', (event) => {
      const ripple = document.createElement('span');
      ripple.className = 'ripple-effect';
      const rect = btn.getBoundingClientRect();
      ripple.style.left = `${event.clientX - rect.left}px`;
      ripple.style.top = `${event.clientY - rect.top}px`;
      btn.appendChild(ripple);
      setTimeout(() => ripple.remove(), 700);
    });
  });

  const heroPrimaryCta = document.getElementById('hero-primary-cta');
  const crimeSection = document.getElementById('crime');
  heroPrimaryCta?.addEventListener('click', (event) => {
    event.preventDefault();
    crimeSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  window.addEventListener('scroll', () => {
    if (!navElement) return;
    const currentScrollY = window.scrollY;
    if (currentScrollY <= 10) {
      navElement.classList.remove('nav-hidden');
      lastScrollY = currentScrollY;
      return;
    }
    if (currentScrollY > lastScrollY && currentScrollY > 90) {
      navElement.classList.add('nav-hidden');
    } else {
      navElement.classList.remove('nav-hidden');
    }
    lastScrollY = currentScrollY;
  }, { passive: true });

  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.reveal').forEach((element) => revealObserver.observe(element));

  const countObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const el = entry.target;
      const raw = el.dataset.target || '0';
      const isInt = !raw.includes('.');
      const end = Number.parseFloat(raw.replace(/[^0-9.]/g, ''));
      if (!Number.isFinite(end)) return;
      const prefix = raw.match(/^[^0-9]*/)?.[0] || '';
      const suffix = raw.match(/[^0-9.]+$/)?.[0] || '';
      const duration = 1600;
      const startTime = performance.now();
      const animate = (now) => {
        const progress = Math.min((now - startTime) / duration, 1);
        const value = (1 - Math.pow(1 - progress, 3)) * end;
        el.textContent = `${prefix}${isInt ? Math.round(value) : value.toFixed(1)}${suffix}`;
        if (progress < 1) requestAnimationFrame(animate);
      };
      requestAnimationFrame(animate);
      countObserver.unobserve(el);
    });
  }, { threshold: 0.4 });

  document.querySelectorAll('.count-up').forEach((element) => countObserver.observe(element));

  async function loadCounter() {
    const counterElement = document.getElementById('counter');
    if (!counterElement) return;
    try {
      const response = await fetch(waitlistEndpoint, { method: 'GET' });
      const data = await response.json().catch(() => ({}));
      const value = Number.parseInt(`${data?.count ?? ''}`, 10);
      counterElement.textContent = Number.isFinite(value) ? value.toLocaleString('en-US') : '-';
    } catch {
      counterElement.textContent = '-';
    }
  }

  loadCounter();

  const form = document.getElementById('waitlist-form');
  const formWrapper = document.getElementById('form-wrapper');
  const successWrapper = document.getElementById('success-wrapper');
  const submitButton = document.getElementById('submit-btn');
  const formStatus = document.getElementById('form-status');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!submitButton || !formStatus) return;

    const emailValue = document.getElementById('email-input')?.value?.trim()?.toLowerCase() || '';
    const expectationValue = document.getElementById('expectation-input')?.value?.trim() || null;
    const honeypotValue = document.getElementById('company-input')?.value?.trim() || '';

    submitButton.setAttribute('disabled', 'true');
    submitButton.textContent = 'Joining...';
    formStatus.textContent = '';

    try {
      const response = await fetch(waitlistEndpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          email: emailValue,
          what_they_expect: expectationValue,
          referrer: document.referrer || null,
          company: honeypotValue
        })
      });

      if (response.ok || response.status === 409) {
        formWrapper?.setAttribute('hidden', 'true');
        successWrapper?.removeAttribute('hidden');
      } else {
        formStatus.textContent = 'Could not submit right now. Please try again.';
        submitButton.removeAttribute('disabled');
        submitButton.textContent = 'Try again';
      }
    } catch {
      formStatus.textContent = 'Network error. Please try again.';
      submitButton.removeAttribute('disabled');
      submitButton.textContent = 'Try again';
    }
  });
</script>
