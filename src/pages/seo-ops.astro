---
import Base from '../layouts/Base.astro';
const lastUpdated = '2026-04-24';
---
<Base
  title="SEO/GEO Operations - DUMB MONEY"
  description="Operational KPI framework and publishing checklist for SEO/GEO."
  modifiedTime={new Date(`${lastUpdated}T00:00:00.000Z`).toISOString()}
>
  <main class="section section-alt">
    <div class="container">
      <h1 class="display h2">SEO/GEO Operations</h1>
      <p class="paragraph"><strong>Cadence:</strong> weekly KPI review, monthly AI citation audit, quarterly framework update.</p>
      <h2 class="display h3">Core KPIs</h2>
      <p class="paragraph">Organic sessions, ranking coverage for PFOF terms, AI citation frequency, AI-referred sessions, and content freshness SLA.</p>
      <h2 class="display h3">Publishing Checklist</h2>
      <p class="paragraph">Every page ships with answer-first summary, FAQ or structured explainer, source links, author/reviewer attribution, and dateModified.</p>
    </div>
  </main>
</Base>
