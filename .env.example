# Copy to .env (never commit .env). Used by Astro server routes locally.
# Vercel / Netlify: set the same keys in Project → Environment Variables (runtime `process.env`).

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Optional (IndexNow / other scripts)
# INDEXNOW_KEY=
# INDEXNOW_HOST=dumb-moneyy.vercel.app
